# Copy this file to .env.local and fill in your own API keys.
# All keys are OPTIONAL here — you can instead enter keys in the app UI
# (Settings → API Keys), which stores them in your browser only.
# Keys entered in the browser take priority over these values.

# OpenAI — powers GPT models (chat, prompt wizard, workflow generation)
# Get a key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic — powers Claude models
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# AccuWeather — powers the weather tool (optional)
# Get a key: https://developer.accuweather.com/
ACCUWEATHER_API_KEY=

# API server port (optional, defaults to 3001)
# PORT=3001
